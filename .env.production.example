# ============================================================
#  NexusAI — PRODUCTION Environment
# ============================================================

# App
NODE_ENV=production
APP_ENV=production
APP_NAME=NexusAI
APP_SECRET_KEY=CHANGE_ME_64_CHAR_RANDOM_STRING_HERE_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEBUG=false
DOMAIN=nexusai.com

# Database
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DATABASE_URL=postgresql+asyncpg://nexusai:CHANGE_ME_STRONG_DB_PASSWORD@postgres:5432/nexusai
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_STRONG_REDIS_PASSWORD@redis:6379/0

# Auth
JWT_SECRET=CHANGE_ME_64_CHAR_JWT_SECRET_HERE_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# CORS
ALLOWED_ORIGINS=https://nexusai.com,https://app.nexusai.com

# LLM Providers
NVIDIA_API_KEY=nvapi-your-key-here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_DEFAULT_MODEL=openai/gpt-oss-120b
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
TOGETHER_API_KEY=

# Monitoring
SENTRY_DSN=https://xxx@sentry.io/xxx
PROMETHEUS_ENABLED=true
JAEGER_ENDPOINT=http://jaeger:4318/v1/traces
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# Storage
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=100
S3_BUCKET=nexusai-production
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000

# Email (SendGrid)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=SG.your-key-here

# Frontend
NEXT_PUBLIC_API_URL=https://nexusai.com
NEXT_PUBLIC_WS_URL=wss://nexusai.com

# Docker
DOCKER_REGISTRY=ghcr.io/your-username
VERSION=latest

# Feature Flags
ENABLE_NEW_WORKFLOW_UI=true
ENABLE_ADVANCED_RAG=false
ENABLE_DEV_AGENT=true
