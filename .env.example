# ============================================================
#  NexusAI — Environment Configuration
# ============================================================

# ── App ──────────────────────────────────────────────────────
APP_NAME=NexusAI
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-random-64-char-string
DEBUG=true

# ── Database ─────────────────────────────────────────────────
POSTGRES_PASSWORD=nexusai_secret
DATABASE_URL=postgresql+asyncpg://nexusai:nexusai_secret@localhost:5432/nexusai

# ── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:redis_secret@localhost:6379/0

# ── LLM Providers ────────────────────────────────────────────
# NVIDIA (primary — already configured)
NVIDIA_API_KEY=nvapi-your-key-here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_DEFAULT_MODEL=openai/gpt-oss-120b

# OpenAI (optional)
# OPENAI_API_KEY=sk-your-key-here

# Anthropic (optional)
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Groq (optional — free, very fast)
# GROQ_API_KEY=gsk_your-key-here

# Mistral (optional)
# MISTRAL_API_KEY=your-key-here

# Together AI (optional)
# TOGETHER_API_KEY=your-key-here

# Local Ollama (optional)
# OLLAMA_BASE_URL=http://localhost:11434

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET=change-me-to-another-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ── Storage ──────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=100

# ── Monitoring ───────────────────────────────────────────────
GRAFANA_PASSWORD=admin
SENTRY_DSN=

# ── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
